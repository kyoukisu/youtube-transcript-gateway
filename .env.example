HOST=0.0.0.0
PORT=8091

# Optional bearer protection for inbound requests
INBOUND_API_TOKEN=

# Comma-separated proxy URLs. Example:
# PROXIES=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
PROXIES=
PROXY_FALLBACK_TO_DIRECT=true
PROXY_COOLDOWN_SECONDS=60
PROXY_MIN_INTERVAL_SECONDS=0
PROXY_WAIT_FOR_SLOT_SECONDS=2

REQUEST_TIMEOUT_SECONDS=45
MAX_ATTEMPTS=8
LANGUAGES_DEFAULT=en
USER_AGENT=youtube-transcript-gateway/0.1 (+https://github.com/)

CACHE_TTL_SECONDS=21600
CACHE_MAX_ITEMS=1000
